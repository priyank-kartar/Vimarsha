# Vimarsha premium narration worker — real (sequential) Chatterbox on RunPod serverless.
# Uses the `tts` extra (chatterbox-tts + torch), NOT the vLLM batched port — the port mangled
# the audio, so the worker narrates the same per-block path as local Chatterbox.
FROM nvidia/cuda:12.4.1-devel-ubuntu22.04

RUN apt-get update && apt-get install -y --no-install-recommends \
        ffmpeg git curl ca-certificates \
    && rm -rf /var/lib/apt/lists/*

RUN curl -LsSf https://astral.sh/uv/install.sh | sh
ENV PATH="/root/.local/bin:${PATH}"

WORKDIR /app
COPY pyproject.toml uv.lock .python-version README.md ./
COPY src ./src
COPY serverless ./serverless
RUN --mount=type=cache,target=/root/.cache/uv \
    uv python install 3.13 && uv sync --extra tts --frozen --no-dev

# RunPod invokes the handler; uv run gives it the project venv (with the vimarsha package).
CMD ["uv", "run", "python", "serverless/rp_handler.py"]

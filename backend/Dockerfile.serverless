# Vimarsha premium narration worker — Chatterbox on RunPod serverless.
FROM nvidia/cuda:12.4.1-runtime-ubuntu22.04

RUN apt-get update && apt-get install -y --no-install-recommends \
        ffmpeg git curl ca-certificates \
    && rm -rf /var/lib/apt/lists/*

RUN curl -LsSf https://astral.sh/uv/install.sh | sh
ENV PATH="/root/.local/bin:${PATH}"

WORKDIR /app
COPY pyproject.toml uv.lock .python-version README.md ./
COPY src ./src
COPY serverless ./serverless
# chatterbox-vllm loads the T3 transformer as a vLLM model from ./t3-model (relative to CWD=/app)
# and symlinks the weights into it at runtime; the dir + config.json must pre-exist.
COPY serverless/t3-model ./t3-model
RUN uv python install 3.13 && uv sync --extra serverless --frozen --no-dev

# RunPod invokes the handler; uv run gives it the project venv (with the vimarsha package).
CMD ["uv", "run", "python", "serverless/rp_handler.py"]

<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Keep audio playing when the app is backgrounded or the device is locked. Not
	     expressible via INFOPLIST_KEY_* build settings, so this partial plist supplies it;
	     GENERATE_INFOPLIST_FILE=YES still merges the generated keys on top. -->
	<key>UIBackgroundModes</key>
	<array>
		<string>audio</string>
	</array>
	<!-- Share-to-Vimarsha: register as an EPUB handler so "Copy to Vimarsha" / "Open in
	     Vimarsha" appears in the share sheet and Files. The inbound file is handled in
	     VimarshaApp.onOpenURL → LibraryStore.addBook. `org.idpf.epub-container` is the
	     system-declared UTI for .epub. -->
	<key>CFBundleDocumentTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeName</key>
			<string>EPUB Book</string>
			<key>CFBundleTypeRole</key>
			<string>Viewer</string>
			<key>LSHandlerRank</key>
			<string>Default</string>
			<key>LSItemContentTypes</key>
			<array>
				<string>org.idpf.epub-container</string>
			</array>
		</dict>
	</array>
	<!-- Required by Apple (ITMS-90737) once CFBundleDocumentTypes is declared. We read the
	     inbound EPUB in place (security-scoped) and copy it into our container, so YES is
	     correct and Apple-recommended; we don't use a UIDocumentBrowserViewController. -->
	<key>LSSupportsOpeningDocumentsInPlace</key>
	<true/>
</dict>
</plist>

<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- DEV: allow plain-HTTP to the Mac backend on the local network (a LAN IP, not
	     localhost, so it needs an ATS exception). NSAllowsLocalNetworking covers private
	     IPv4 + .local without opening arbitrary loads. Remove when the backend is HTTPS
	     (hosted scope). -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>
</dict>
</plist>
